<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph.xml"
    app:startDestination="@id/ekranPowitalny">

    <fragment
        android:id="@+id/ekranPowitalny"
        android:name="com.example.navigation.EkranPowitalny"
        android:label="fragment_ekran_powitalny"
        tools:layout="@layout/fragment_ekran_powitalny" >
        <action
            android:id="@+id/action_ekranPowitalny_to_dodawanieUzytkownika"
            app:destination="@id/dodawanieUzytkownika" />
        <action
            android:id="@+id/action_ekranPowitalny_to_memory"
            app:destination="@id/memory" />
    </fragment>
    <fragment
        android:id="@+id/dodawanieUzytkownika"
        android:name="com.example.navigation.DodawanieUzytkownika"
        android:label="fragment_dodawanie_uzytkownika"
        tools:layout="@layout/fragment_dodawanie_uzytkownika" >
        <action
            android:id="@+id/action_dodawanieUzytkownika_to_ekranPowitalny"
            app:destination="@id/ekranPowitalny" />
    </fragment>
    <fragment
        android:id="@+id/memory"
        android:name="com.example.navigation.Memory"
        android:label="fragment_memory"
        tools:layout="@layout/fragment_memory" >
        <action
            android:id="@+id/action_memory_to_ekranPowitalny"
            app:destination="@id/ekranPowitalny" />
        <action
            android:id="@+id/action_memory_to_listaWynikow"
            app:destination="@id/listaWynikow" />
        <action
            android:id="@+id/action_memory_to_ustawienia"
            app:destination="@id/ustawienia" />
    </fragment>
    <fragment
        android:id="@+id/listaWynikow"
        android:name="com.example.navigation.ListaWynikow"
        android:label="fragment_lista_wynikow"
        tools:layout="@layout/fragment_lista_wynikow" >
        <action
            android:id="@+id/action_listaWynikow_to_memory"
            app:destination="@id/memory" />
    </fragment>
    <fragment
        android:id="@+id/ustawienia"
        android:name="com.example.navigation.Ustawienia"
        android:label="fragment_ustawienia"
        tools:layout="@layout/fragment_ustawienia" >
        <action
            android:id="@+id/action_ustawienia_to_memory"
            app:destination="@id/memory" />
    </fragment>
</navigation>